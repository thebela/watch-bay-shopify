          "label": "Desktop placement",
          "options": [
            { "value": "text", "label": "Text column" },
            { "value": "media", "label": "Media column" },
            { "value": "full", "label": "Full width" }
          ],
          "default": "full"
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        }
      ]
    },
    {
      "type": "divider",
      "name": "Divider",
      "settings": [
        {
          "type": "select",
          "id": "placement",
