        },
        {
          "type": "select",
          "id": "placement",
          "label": "Desktop placement",
          "options": [
            { "value": "text", "label": "Text column" },
            { "value": "media", "label": "Media column" },
            { "value": "full", "label": "Full width" }
          ],
          "default": "text"
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Explore Collection"
        },
        {
          "type": "url",
          "id": "link",
