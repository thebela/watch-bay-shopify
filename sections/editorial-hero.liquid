  ],
  "presets": [
    {
      "name": "Editorial hero",
      "category": "Banners",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "text" },
        { "type": "button" },
        { "type": "image" },
        { "type": "quote" }
      ]
    }
