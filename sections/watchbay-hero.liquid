{% liquid
  assign hero_image = section.settings.image
  assign image_alt = hero_image.alt | default: section.settings.heading | escape
  assign image_loading = 'lazy'
  assign image_fetchpriority = 'auto'

  if section.index == 1
    assign image_loading = 'eager'
    assign image_fetchpriority = 'high'
  endif
%}

<section
  id="WatchBayHero-{{ section.id }}"
  class="watchbay-hero"
  aria-labelledby="WatchBayHeroHeading-{{ section.id }}"
>
  <div class="watchbay-hero__inner">
    <div class="watchbay-hero__content">
      <p class="watchbay-hero__brand" aria-label="Watch Bay">WATCH BAY</p>

      <h1 id="WatchBayHeroHeading-{{ section.id }}" class="watchbay-hero__heading">
        {{ section.settings.heading | escape }}
      </h1>

      <p class="watchbay-hero__description">
        {{ section.settings.description | escape }}
      </p>

      {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
        <a class="watchbay-hero__cta" href="{{ section.settings.cta_link }}">
          {{ section.settings.cta_label | escape }}
          <span aria-hidden="true">→</span>
        </a>
      {% endif %}
    </div>

    <figure class="watchbay-hero__media" aria-label="Featured Watch Bay timepiece">
      {% if hero_image != blank %}
        {{
          hero_image
          | image_url: width: 1800
          | image_tag:
            widths: '360, 540, 720, 960, 1200, 1500, 1800',
            sizes: '(min-width: 990px) 360px, (min-width: 750px) 42vw, 78vw',
            loading: image_loading,
            fetchpriority: image_fetchpriority,
            alt: image_alt,
            class: 'watchbay-hero__image'
        }}
      {% else %}
        {{ 'product-apparel-1' | placeholder_svg_tag: 'watchbay-hero__placeholder' }}
      {% endif %}

      <figcaption class="watchbay-hero__caption">Zenith</figcaption>
    </figure>
  </div>
</section>

<style>
  /* Scoped to this section instance so the custom hero never leaks into Dwell defaults. */
  #WatchBayHero-{{ section.id }} {
    --watchbay-bg: #050505;
    --watchbay-text: #f7f3ec;
    --watchbay-muted: rgba(247, 243, 236, 0.68);
    --watchbay-line: rgba(247, 243, 236, 0.18);
    --watchbay-accent: #d7c19a;

    background:
      radial-gradient(circle at 50% 115%, rgba(215, 193, 154, 0.16), transparent 34rem),
      linear-gradient(180deg, #111 0%, var(--watchbay-bg) 42%, #020202 100%);
    color: var(--watchbay-text);
    min-height: clamp(640px, 100svh, 920px);
    overflow: hidden;
    position: relative;
  }

  #WatchBayHero-{{ section.id }}::before,
  #WatchBayHero-{{ section.id }}::after {
    content: "";
    left: 50%;
    pointer-events: none;
    position: absolute;
    transform: translateX(-50%);
    width: min(78rem, calc(100% - 2rem));
  }

  #WatchBayHero-{{ section.id }}::before {
    border-top: 1px solid var(--watchbay-line);
    top: 1.5rem;
  }

  #WatchBayHero-{{ section.id }}::after {
    border-bottom: 1px solid var(--watchbay-line);
    bottom: 1.5rem;
  }

  #WatchBayHero-{{ section.id }} .watchbay-hero__inner {
    align-items: center;
    display: grid;
    gap: clamp(2.5rem, 8vw, 5.5rem);
    justify-items: center;
    margin-inline: auto;
    max-width: 78rem;
    min-height: inherit;
    padding: clamp(4.5rem, 9vw, 7rem) 1.25rem;
    position: relative;
    text-align: center;
    z-index: 1;
  }

  #WatchBayHero-{{ section.id }} .watchbay-hero__content {
    display: grid;
    gap: 1.2rem;
    justify-items: center;
    max-width: 43rem;
  }

  #WatchBayHero-{{ section.id }} .watchbay-hero__brand {
    color: var(--watchbay-muted);
    font-family: var(--font-body--family, system-ui, sans-serif);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    line-height: 1;
    margin: 0 0 0.25rem;
    text-transform: uppercase;
  }

  #WatchBayHero-{{ section.id }} .watchbay-hero__heading {
    color: var(--watchbay-text);
    font-family: var(--font-heading--family, Georgia, serif);
    font-size: clamp(3rem, 11vw, 7.5rem);
    font-weight: 400;
    letter-spacing: 0;
    line-height: 0.95;
    margin: 0;
  }

  #WatchBayHero-{{ section.id }} .watchbay-hero__description {
    color: var(--watchbay-muted);
    font-family: var(--font-body--family, system-ui, sans-serif);
    font-size: clamp(1rem, 2.5vw, 1.22rem);
    line-height: 1.65;
    margin: 0;
    max-width: 34rem;
  }

  #WatchBayHero-{{ section.id }} .watchbay-hero__cta {
    align-items: center;
    color: var(--watchbay-text);
    display: inline-flex;
    font-family: var(--font-body--family, system-ui, sans-serif);
    font-size: 0.84rem;
    font-weight: 600;
    gap: 0.45rem;
    letter-spacing: 0.12em;
    line-height: 1;
    margin-top: 0.85rem;
    min-height: 44px;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 180ms ease, transform 180ms ease;
  }

  #WatchBayHero-{{ section.id }} .watchbay-hero__cta:hover {
    color: var(--watchbay-accent);
    transform: translateY(-1px);
  }

  #WatchBayHero-{{ section.id }} .watchbay-hero__cta:focus-visible {
    outline: 1px solid var(--watchbay-accent);
    outline-offset: 0.45rem;
  }

  #WatchBayHero-{{ section.id }} .watchbay-hero__media {
    display: grid;
    gap: 1rem;
    justify-items: center;
    margin: 0;
    width: min(78vw, 22rem);
  }

  #WatchBayHero-{{ section.id }} .watchbay-hero__image,
  #WatchBayHero-{{ section.id }} .watchbay-hero__placeholder {
    aspect-ratio: 1;
    border-radius: 999px;
    display: block;
    filter: drop-shadow(0 2rem 3.5rem rgba(0, 0, 0, 0.6));
    height: auto;
    object-fit: cover;
    width: 100%;
  }

  #WatchBayHero-{{ section.id }} .watchbay-hero__placeholder {
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.22);
  }

  #WatchBayHero-{{ section.id }} .watchbay-hero__caption {
    color: rgba(247, 243, 236, 0.82);
    font-family: var(--font-heading--family, Georgia, serif);
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    letter-spacing: 0.03em;
  }

  @media screen and (min-width: 750px) {
    #WatchBayHero-{{ section.id }} .watchbay-hero__inner {
      padding-inline: 2rem;
    }
  }

  @media screen and (min-width: 990px) {
    #WatchBayHero-{{ section.id }} .watchbay-hero__inner {
      grid-template-rows: 1fr auto;
    }

    #WatchBayHero-{{ section.id }} .watchbay-hero__content {
      transform: translateY(2rem);
    }

    #WatchBayHero-{{ section.id }} .watchbay-hero__media {
      width: min(28vw, 23.5rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #WatchBayHero-{{ section.id }} .watchbay-hero__cta {
      transition: none;
    }
  }
</style>

{% schema %}
{
  "name": "Watch Bay hero",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Watch image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Time, Perfected."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover exceptional timepieces crafted for those who value precision over trends."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Watch Bay hero",
      "category": "Banners"
    }
  ]
}
{% endschema %}
